# Pi-Wielder spike — environment template. Copy to .env and fill in.
# NEVER commit a real .env (the repo root .gitignore already excludes it).
# Mock mode (`npm run e2e`) needs NONE of these.

# --- the Wielder wallet (testnet ONLY — never a mainnet key) -----------------
# 0x-prefixed private key of a throwaway Base Sepolia account.
# Fund it with testnet USDC + ETH via the Coinbase CDP faucet (see RUNBOOK.md).
PRIVATE_KEY=

# Where sellers receive USDC (collar + gateway payTo). Any address you control.
PAY_TO_ADDRESS=

# --- upstream model keys (sellers' side; only needed without MOCK_LLM=1) -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- modes -------------------------------------------------------------------
# 1 = in-process fake facilitator (offline). Unset/0 = real facilitator below.
MOCK_FACILITATOR=1
# 1 = canned completions/skill output, no model keys needed.
MOCK_LLM=1
FACILITATOR_URL=https://x402.org/facilitator

# --- ports (defaults shown; 8402 is a nod to ClawRouter's paying proxy) ------
PROXY_PORT=8402
GATEWAY_PORT=8403
COLLAR_PORT=8404
# Proxy -> seller wiring (defaults match the ports above)
GATEWAY_URL=http://127.0.0.1:8403
COLLAR_URL=http://127.0.0.1:8404
# Optional JSONL session-ledger path for the proxy
LEDGER_FILE=

# --- pricing (USDC per call) --------------------------------------------------
SKILL_PRICE_USDC=0.25
